# Root-level env is only for compose-level overrides.
# Backend Supabase credentials belong in tradescenter-backend/.env.
FLASK_SECRET_KEY=replace-with-a-long-random-secret
SUPABASE_AUTH_MODE=local

# Local infra override values used by docker-compose.local.yml.
LOCAL_SUPABASE_PORT=54321
LOCAL_SUPABASE_DB=postgres
LOCAL_SUPABASE_DB_USER=postgres
LOCAL_SUPABASE_DB_PASSWORD=postgres
LOCAL_SUPABASE_JWT_SECRET=tradescenter-local-jwt-secret-with-at-least-32-chars
